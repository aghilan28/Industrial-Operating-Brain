# =============================================================================
# INDUSTRIAL OPERATING BRAIN (IOB) — PHASE 7 ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy to `.env` beside docker-compose.yml, then: docker compose up -d --build
#     cp .env.example .env
#
# Every variable below is consumed by docker-compose.yml. The container-side
# names it injects are the ones the application code ACTUALLY reads
# (backend/apps/core/config.py and ai-platform/app/core/config.py) — see the
# annotations on each block.
#
# NEVER commit the populated .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Compose composes these into DATABASE_URL / IOB_POSTGRES_DSN, which is the
# variable the backend Settings class actually reads (it does NOT read
# POSTGRES_HOST). Driver is asyncpg.
POSTGRES_DB=iob_db
POSTGRES_USER=iob_user
POSTGRES_PASSWORD=iob_password
# Host-side debug port, bound to 127.0.0.1 only. Container port stays 5432.
POSTGRES_HOST_PORT=5433

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Injected as REDIS_URL=redis://:<password>@redis:6379/0 for the backend and
# database 1 for the ai-platform.
REDIS_PASSWORD=redis_secret_password
REDIS_HOST_PORT=6379

# -----------------------------------------------------------------------------
# Mosquitto MQTT
# -----------------------------------------------------------------------------
# Backend reads MQTT_BROKER_HOST / MQTT_BROKER_PORT (compose sets them to
# mosquitto:1883). Leave username/password blank while mosquitto.conf runs
# `allow_anonymous true`.
MQTT_HOST_PORT=1883
MQTT_WS_HOST_PORT=9001
MQTT_CLIENT_ID=iob-backend
MQTT_USERNAME=
# REQUIRED (non-empty) if you set BACKEND_ENV=production — the backend's
# validate_production_boundaries() raises on a blank MQTT_PASSWORD.
MQTT_PASSWORD=

# -----------------------------------------------------------------------------
# Neo4j
# -----------------------------------------------------------------------------
# NEO4J_AUTH must stay in sync with NEO4J_USER / NEO4J_PASSWORD: the compose
# healthcheck authenticates with cypher-shell using the split values.
NEO4J_USER=neo4j
NEO4J_PASSWORD=iob_password
NEO4J_AUTH=neo4j/iob_password
NEO4J_DATABASE=neo4j
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687
# JVM sizing — keep heap max below the 2048M container limit.
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1024m
NEO4J_PAGECACHE=512m

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
# Image pinned to v1.11.3 to match qdrant-client==1.11.3.
QDRANT_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334

# -----------------------------------------------------------------------------
# AI Platform  (ai-platform/Dockerfile — uvicorn on container port 8000)
# -----------------------------------------------------------------------------
# NOTE: the service listens on 8000 INSIDE the container and is published to
# 127.0.0.1:8001 on the host. Backend talks to http://ai-platform:8000.
AI_PLATFORM_HOST_PORT=8001
# development => InternalOnlyGuardMiddleware logs a warning and allows calls.
# production  => every non-allowlisted route demands X-Internal-Service-Token.
AI_APP_ENV=development
AI_CORS_ALLOW_ORIGINS=http://localhost,http://localhost:3000
# Shared secret between backend and ai-platform (guard's SERVICE_API_KEY).
INTERNAL_SERVICE_TOKEN=development

# -----------------------------------------------------------------------------
# Backend  (FastAPI — container port 8000)
# -----------------------------------------------------------------------------
BACKEND_HOST_PORT=8000
# Setting either of these to `production` activates strict validation:
# SECRET_KEY >= 32 chars AND non-default, MQTT_PASSWORD non-empty,
# DATABASE_URL explicitly set. Startup raises otherwise.
BACKEND_ENV=development
BACKEND_ENVIRONMENT=development
BACKEND_DEBUG=false
# Change before any production run. Must be >= 32 characters.
SECRET_KEY=dev_only_secret_key_change_me_32_chars_min
AI_SERVICE_TIMEOUT=30
# Browser origin is the edge proxy on port 80.
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend  (Next.js 15 SSR — container port 3000, no host port)
# -----------------------------------------------------------------------------
# Leave BOTH URL values EMPTY. Empty means the browser uses relative URLs and
# derives ws:// from window.location, so all traffic flows through the edge
# proxy on a single origin (no CORS, and automatic wss:// upgrade under TLS).
#
# src/api/client.ts defaults to '/api/v1' when unset, while
# src/lib/api/axiosClient.ts prefixes full paths like '/api/v1/auth/login'.
# An empty value is the only setting that satisfies both clients.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_APP_ENV=production

# -----------------------------------------------------------------------------
# Edge reverse proxy (the ONLY service published on a public interface)
# -----------------------------------------------------------------------------
EDGE_HTTP_PORT=80

# -----------------------------------------------------------------------------
# Platform-wide
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
