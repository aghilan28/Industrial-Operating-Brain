# Industrial Operating Brain - Frontend Environment Template
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=production

# --- Phase 5: Real-Time Streaming ---
# Leave NEXT_PUBLIC_WS_URL unset to let StreamProvider derive the socket URL
# from window.location (recommended: works behind the Next.js rewrite proxy and
# automatically upgrades ws: -> wss: on HTTPS deployments).
#
# Set it explicitly only when the stream terminates on a different origin than
# the web app, e.g. a dedicated gateway:
#   Legacy transport      : ws://localhost:8000/api/v1/stream
#   Versioned envelopes   : ws://localhost:8000/api/v1/ws/telemetry/<client-id>
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/stream
